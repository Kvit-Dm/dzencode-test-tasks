{
  "compilerOptions": {
    "target": "ES2022",                   // Modern Node support (private fields, async/await)
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,                       // Allow JS files
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,                       // Needed for ts-node scripts
    "esModuleInterop": true,               // Default imports from CommonJS modules
    "module": "ESNext",
    "outDir": "dist",
    "moduleResolution": "NodeNext",        // Correct module resolution for ESM
    "resolveJsonModule": true,             // Allow importing JSON files
    "isolatedModules": true,
    "incremental": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/scripts/**/*.ts",                 // Include Node scripts
    "_data/**/*.json",                     // Include JSON data
    "**/*.json"
  ],
  "exclude": ["node_modules"]
}


